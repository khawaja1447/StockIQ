# StockIQ Environment Variables
# Copy this file to .env and fill in your values

# Optional: Reddit API credentials for richer sentiment data
# Get free credentials at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=StockIQ/1.0

# Optional: NewsAPI key for news sentiment
# Get free key at https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# Without any API keys, StockIQ still works using:
# - Reddit's public JSON feed (no auth required)
# - Yahoo Finance news (via yfinance)
# - CoinGecko free API
# - Alternative.me Fear & Greed API
